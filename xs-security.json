{
  "xsappname": "xsuaa-jwt",
  "tenant-mode": "dedicated",
  "scopes": [
    {
      "name": "$XSAPPNAME.Display",
      "description": "View resources"
    },
    {
      "name": "$XSAPPNAME.Edit",
      "description": "Edit resources"
    },
    {
      "name": "$XSAPPNAME.Delete",
      "description": "Delete resources"
    },
    {
      "name": "$XSAPPNAME.support",
      "description": "support"
    },
    {
      "name": "$XSAPPNAME.admin",
      "description": "admin"
    }
  ],
  "role-templates": [
    {
      "name": "support",
      "description": "support",
      "scope-references": [
        "$XSAPPNAME.support"
      ]
    },
    {
      "name": "admin",
      "description": "admin",
      "scope-references": [
        "$XSAPPNAME.admin"
      ]
    }
  ],
  "oauth2-configuration": {
    "redirect-uris": [
      "https://httpbin.org/get"
    ]
  }
}
