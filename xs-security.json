{
  "xsappname": "incident-management",
  "tenant-mode": "dedicated",
  "scopes": [
    {
      "name": "$XSAPPNAME.support",
      "description": "support"
    },
    {
      "name": "$XSAPPNAME.admin",
      "description": "admin"
    }
  ],
  "role-templates": [
    {
      "name": "support",
      "description": "support",
      "scope-references": [
        "$XSAPPNAME.support"
      ]
    },
    {
      "name": "admin",
      "description": "admin",
      "scope-references": [
        "$XSAPPNAME.admin"
      ]
    }
  ],
  "oauth2-configuration": {
    "redirect-uris": [
      "https://*.hana.ondemand.com/**",
      "https://*.launchpad.cfapps.us10.hana.ondemand.com/**"
    ]
  }
}
